#!/bin/sh

SESSION_FILE="/tmp/quickfile-session.active"
WATCHER_PID="/tmp/quickfile-session-watchdog.pid"
TTL="${QUICKFILE_SESSION_TTL:-20}"

now() {
  date +%s
}

is_running() {
  pidof quickfile >/dev/null 2>&1
}

stop_quickfile() {
  rm -f "$SESSION_FILE"
  [ -x /etc/init.d/quickfile ] && /etc/init.d/quickfile stop >/dev/null 2>&1 || true
}

start_watcher() {
  if [ -f "$WATCHER_PID" ] && kill -0 "$(cat "$WATCHER_PID" 2>/dev/null)" 2>/dev/null; then
    return
  fi

  (
    while :; do
      sleep 5
      [ -f "$SESSION_FILE" ] || break
      last="$(cat "$SESSION_FILE" 2>/dev/null || echo 0)"
      case "$last" in
        ''|*[!0-9]*) last=0 ;;
      esac
      if [ $(( $(now) - last )) -gt "$TTL" ]; then
        stop_quickfile
        break
      fi
    done
    rm -f "$WATCHER_PID"
  ) &
  echo "$!" > "$WATCHER_PID"
}

case "${1:-status}" in
  enable|heartbeat)
    now > "$SESSION_FILE"
    if [ "${1:-}" = "enable" ]; then
      [ -x /etc/init.d/quickfile ] && /etc/init.d/quickfile start >/dev/null 2>&1
    fi
    start_watcher
    ;;
  disable)
    stop_quickfile
    ;;
  status)
    if [ -f "$SESSION_FILE" ] && is_running; then
      echo "enabled"
    else
      echo "disabled"
    fi
    ;;
  *)
    echo "Usage: $0 {enable|heartbeat|disable|status}" >&2
    exit 2
    ;;
esac

exit 0
